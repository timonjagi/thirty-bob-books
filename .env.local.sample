# Thirty Bob Books - Environment Variables

# Google Spreadsheet ID for your ebooks catalog
GOOGLE_SPREADSHEET_ID_PRODUCT=your_google_spreadsheet_id_for_ebooks_here

# Google Spreadsheet ID for tracking downloads/orders
GOOGLE_SPREADSHEET_ID_ORDER=your_google_spreadsheet_id_for_orders_here

# Google Service Account credentials
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=your_google_service_account_client_email_here
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=your_google_service_account_private_key_here
